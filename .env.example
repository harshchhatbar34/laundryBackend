# ─── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/laundry_db

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=30d

# ─── OTP ───────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
# Set OTP_PROVIDER=mock for dev (logs OTP to console)
# Set OTP_PROVIDER=msg91 | twilio | fast2sms for production
OTP_PROVIDER=mock

# MSG91 (if OTP_PROVIDER=msg91)
# MSG91_AUTH_KEY=your_msg91_auth_key
# MSG91_TEMPLATE_ID=your_template_id

# Twilio (if OTP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

