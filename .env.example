# ─── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/laundry_db

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=30d

# ─── Super Admin Seed ──────────────────────────────
# Used only in seed script to bootstrap the first superadmin account
SUPERADMIN_EMAIL=superadmin@laundry.com
SUPERADMIN_PASSWORD=SuperAdmin@2026
